class_name ResultsScreen
extends Control
signal continue_requested
signal main_menu_requested
func setup(level_title:String,time_remaining:float,uses_timer:bool)->void:
 set_anchors_and_offsets_preset(Control.PRESET_FULL_RECT);process_mode=Node.PROCESS_MODE_ALWAYS;var shade:=ColorRect.new();shade.color=Color(0,0,0,.78);shade.set_anchors_and_offsets_preset(Control.PRESET_FULL_RECT);add_child(shade);var panel:=PanelContainer.new();panel.add_theme_stylebox_override("panel",UIFactory.panel_style());panel.set_anchors_preset(Control.PRESET_CENTER);panel.position=Vector2(-310,-380);panel.size=Vector2(620,760);shade.add_child(panel);var box:=VBoxContainer.new();box.alignment=BoxContainer.ALIGNMENT_CENTER;box.add_theme_constant_override("separation",18);panel.add_child(box);box.add_child(UIFactory.make_title("TRIAL COMPLETE",48));box.add_child(UIFactory.make_title(level_title,30));var stats:=Label.new();stats.horizontal_alignment=HORIZONTAL_ALIGNMENT_CENTER;stats.add_theme_font_size_override("font_size",23);stats.text=("Time Remaining: %.1f\n"%time_remaining if uses_timer else "")+"Damage Taken: %d\nMistakes: %d\nSigils: %d / 4\n\nRANK: %s"%[GameState.damage_taken,GameState.mistakes,GameState.sigil_count(),GameState.calculate_rank(time_remaining,uses_timer)];stats.custom_minimum_size=Vector2(480,300);box.add_child(stats);var cont:=UIFactory.make_button("Continue");cont.pressed.connect(func()->void:continue_requested.emit());box.add_child(cont);var menu:=UIFactory.make_button("Main Menu");menu.pressed.connect(func()->void:main_menu_requested.emit());box.add_child(menu)
