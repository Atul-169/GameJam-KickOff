 set_anchors_and_offsets_preset(Control.PRESET_FULL_RECT);var bg:=ColorRect.new();bg.color=Color("08141f");bg.set_anchors_and_offsets_preset(Control.PRESET_FULL_RECT);add_child(bg);var box:=VBoxContainer.new();box.set_anchors_preset(Control.PRESET_CENTER);box.position=Vector2(-520,-310);box.size=Vector2(1040,620);box.alignment=BoxContainer.ALIGNMENT_CENTER;box.add_theme_constant_override("separation",25);bg.add_child(box);box.add_child(UIFactory.make_title("THE FIRST KICK",74));box.add_child(UIFactory.make_title("Every beginning is a choice.",31));var story:=Label.new();story.text="NIKO: You kicked an ancient nightmare back into its box.\nARIN: You chased my football into a cursed forest.\nNIKO: So this is still your fault.\nARIN: Mostly.\nNIKO: Try not to kick it into another dimension.\nARIN: No promises.";story.horizontal_alignment=HORIZONTAL_ALIGNMENT_CENTER;story.add_theme_font_size_override("font_size",23);story.custom_minimum_size=Vector2(900,270);box.add_child(story);var menu:=UIFactory.make_button("Main Menu");menu.pressed.connect(func()->void:main_menu_requested.emit());box.add_child(menu);AudioManager.play_music("ending_music")
